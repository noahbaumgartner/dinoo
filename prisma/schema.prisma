generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// main models
model User {
  id            String    @id @default(uuid())
  sessions      Session[]
  username      String    @unique
  firstName     String
  lastName      String
  password_hash String
  Order         Order[]
}

model Session {
  id        String   @id
  userId    String
  expiresAt DateTime

  user User @relation(references: [id], fields: [userId], onDelete: Cascade)
}

model Menu {
  id          String     @id @default(uuid())
  name        String
  description String
  MenuArea    MenuArea[]
}

model MenuArea {
  id            String          @id @default(uuid())
  name          String
  icon          String
  color         String
  MenuGroupItem MenuGroupItem[]

  menuId String
  menu   Menu   @relation(fields: [menuId], references: [id])
}

model Product {
  id            String          @id @default(uuid())
  name          String
  price         Float
  MenuGroupItem MenuGroupItem[]
  OrderItem     OrderItem[]
  Modifier      Modifier[]
}

model Order {
  id        String      @id @default(uuid())
  completed Boolean     @default(false)
  userId    String
  tableId   String
  OrderItem OrderItem[]
  user      User        @relation(fields: [userId], references: [id])
  Payment   Payment[]
}

model Modifier {
  id                String              @id @default(uuid())
  name              String
  price             Float
  productId         String
  product           Product             @relation(fields: [productId], references: [id])
  OrderItemModifier OrderItemModifier[]
}

model Payment {
  id          String        @id @default(uuid())
  type        String
  Order       Order?        @relation(fields: [orderId], references: [id])
  orderId     String?
  PaymentItem PaymentItem[]
}

// conntected models
model MenuGroupItem {
  id          String   @id @default(uuid())
  menuGroupId String
  productId   String
  menuArea    MenuArea @relation(fields: [menuGroupId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
}

model OrderItem {
  id                String              @id @default(uuid())
  orderId           String
  productId         String
  quantity          Int
  order             Order               @relation(fields: [orderId], references: [id])
  product           Product             @relation(fields: [productId], references: [id])
  OrderItemModifier OrderItemModifier[]
  PaymentItem       PaymentItem[]
}

model OrderItemModifier {
  id          String    @id @default(uuid())
  orderItemId String
  modifierId  String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  modifier    Modifier  @relation(fields: [modifierId], references: [id])
}

model PaymentItem {
  id          String    @id @default(uuid())
  quantity    Int
  orderItemId String
  paymentId   String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  payment     Payment   @relation(fields: [paymentId], references: [id])
}
